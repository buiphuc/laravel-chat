{
    "name": "phucbui/laravel-chat",
    "description": "A flexible realtime chat package for Laravel with multi-actor support, multiple socket drivers, and capability-based access control.",
    "keywords": ["laravel", "chat", "realtime", "websocket", "reverb", "socketio", "pusher"],
    "license": "MIT",
    "authors": [
        {
            "name": "Phuc Bui",
            "email": "phucbui@example.com"
        }
    ],
    "homepage": "https://github.com/phucbui/laravel-chat",
    "support": {
        "issues": "https://github.com/phucbui/laravel-chat/issues",
        "source": "https://github.com/phucbui/laravel-chat"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/broadcasting": "^11.0|^12.0",
        "illuminate/notifications": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhucBui\\Chat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhucBui\\Chat\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhucBui\\Chat\\ChatServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
